# ─── Session (auth-service) ───────────────────────────────────────────────────
SESSION_SECRET=your_session_secret_here

# ─── Google OAuth (auth-service) ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Points to the gateway which proxies to auth-service
GOOGLE_CALLBACK_URL=https://your-gateway-domain.com/api/auth/google/callback

# ─── MongoDB (database-per-service) ──────────────────────────────────────────
# auth-service and user-service share this database (users collection)
MONGODB_AUTH_URI=mongodb://localhost:27017/wowlife_auth
MONGODB_PRODUCTS_URI=mongodb://localhost:27017/wowlife_products
MONGODB_ORDERS_URI=mongodb://localhost:27017/wowlife_orders
MONGODB_CONTENT_URI=mongodb://localhost:27017/wowlife_content

